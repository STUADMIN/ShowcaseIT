generator client {
  provider = "prisma-client-js"
  /// Avoid Windows EPERM on hoisted `node_modules/.prisma` (Next/Cursor locks query_engine DLL).
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /** Email / in-app notification toggles (Settings → Notifications) */
  notifyGuidePublished Boolean   @default(true) @map("notify_guide_published")
  notifyTeamInvites    Boolean   @default(true) @map("notify_team_invites")
  notifyWeeklyDigest   Boolean   @default(false) @map("notify_weekly_digest")
  /** Set by weekly digest cron after a successful send (throttle) */
  weeklyDigestLastSentAt DateTime? @map("weekly_digest_last_sent_at")

  /** Active team for Settings / Publish / Confluence (synced across devices). */
  preferredWorkspaceId String? @map("preferred_workspace_id")
  /** Screen + mic recording: remember voiceover toggle (Settings → Recordings / video flow). */
  recordingMicEnabled  Boolean @default(true) @map("recording_mic_enabled")
  /** Client UI state: e.g. `{ liquidGlass: { ... } }` for workspace visual prefs. */
  uiPreferences        Json    @default("{}") @map("ui_preferences")

  workspaceMembers     WorkspaceMember[]
  recordings           Recording[]
  marketingRenderJobs  MarketingRenderJob[]
  guides               Guide[]
  preferredWorkspace   Workspace? @relation("UserPreferredWorkspace", fields: [preferredWorkspaceId], references: [id], onDelete: SetNull)

  @@map("users")
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  plan      String   @default("free")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /** Confluence Cloud integration (base URL, API token, space, etc.) — stored in Supabase Postgres when DATABASE_URL points there. */
  confluenceIntegration Json? @map("confluence_integration")

  members   WorkspaceMember[]
  projects  Project[]
  brandKits BrandKit[]

  usersPreferringThis User[] @relation("UserPreferredWorkspace")

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  role        String   @default("editor")
  joinedAt    DateTime @default(now()) @map("joined_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Project {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  name        String
  description String?
  brandKitId  String?  @map("brand_kit_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brandKit   BrandKit?  @relation(fields: [brandKitId], references: [id])
  recordings Recording[]
  guides     Guide[]

  @@map("projects")
}

model BrandKit {
  id              String   @id @default(uuid())
  workspaceId     String   @map("workspace_id")
  name            String
  colorPrimary    String   @default("#2563EB") @map("color_primary")
  colorSecondary  String   @default("#7C3AED") @map("color_secondary")
  colorAccent     String   @default("#F59E0B") @map("color_accent")
  colorBackground String   @default("#FFFFFF") @map("color_background")
  colorForeground String   @default("#0F172A") @map("color_foreground")
  fontHeading     String   @default("Inter") @map("font_heading")
  fontBody        String   @default("Inter") @map("font_body")
  logoUrl         String?  @map("logo_url")
  /** Standard guide list / marketing cover; UI prefers this over the first step screenshot when set. */
  guideCoverImageUrl String? @map("guide_cover_image_url")
  /** Wide banner on HTML/PDF/Word exports (below guide cover when both are set). */
  exportBannerDocumentUrl String? @map("export_banner_document_url")
  /** Reserved for link previews / social (e.g. ~1200×627); stored in Brand Kit for future Publish flows. */
  exportBannerSocialUrl String? @map("export_banner_social_url")
  /** Per social platform: { "linkedin": { "logoUrl", "bannerUrl" }, ... } */
  socialPlatformAssets Json @default("{}") @map("social_platform_assets")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects  Project[]
  guides    Guide[]

  @@map("brand_kits")
}

model Recording {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  userId      String   @map("user_id")
  title       String
  videoUrl    String?  @map("video_url")
  duration    Int      @default(0)
  width       Int      @default(1920)
  height      Int      @default(1080)
  mouseEvents Json     @default("[]") @map("mouse_events")
  clickEvents Json     @default("[]") @map("click_events")
  /// Screen recording includes a microphone / voiceover track
  hasVoiceover Boolean @default(false) @map("has_voiceover")
  status      String   @default("processing")
  createdAt   DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
  guides              Guide[]
  marketingRenderJobs MarketingRenderJob[]

  @@map("recordings")
}

/// Async marketing-style outputs from a screen recording (branded video, motion replay, AI pass — see docs/MARKETING_RENDERS.md).
model MarketingRenderJob {
  id          String   @id @default(uuid())
  recordingId String   @map("recording_id")
  userId      String   @map("user_id")
  /// branded_screen | motion_walkthrough | ai_enhanced | branded_plus_motion | full_stack
  mode        String   @map("mode")
  /// queued | processing | ready | failed
  status      String   @default("queued") @map("status")
  /// Public URL when status is ready (e.g. Supabase Storage).
  outputUrl   String?  @map("output_url")
  error       String?  @map("error")
  /// Template / caps / flags — e.g. { "aspectRatio": "16:9", "maxSeconds": 120 }
  options     Json     @default("{}") @map("options")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  recording Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([recordingId])
  @@index([status])
  @@map("marketing_render_jobs")
}

model Guide {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  userId      String   @map("user_id")
  recordingId String?  @map("recording_id")
  brandKitId  String?  @map("brand_kit_id")
  title       String
  description String?
  style       String   @default("clean")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id])
  recording Recording? @relation(fields: [recordingId], references: [id])
  brandKit  BrandKit?  @relation(fields: [brandKitId], references: [id])
  steps     GuideStep[]

  @@map("guides")
}

model GuideStep {
  id                  String   @id @default(uuid())
  guideId             String   @map("guide_id")
  order               Int
  title               String
  description         String   @default("")
  screenshotUrl       String?  @map("screenshot_url")
  /** Pre-crop / pre-replace URL so the editor can restore the full screenshot after crop. */
  screenshotOriginalUrl String? @map("screenshot_original_url")
  styledScreenshotUrl String?  @map("styled_screenshot_url")
  annotations         Json     @default("[]")
  blurRegions         Json     @default("[]") @map("blur_regions")
  mousePosition       Json?    @map("mouse_position")
  clickTarget         Json?    @map("click_target")
  timestamp           Int?
  /** When false, step is omitted from HTML export (still visible in editor). */
  includeInExport     Boolean  @default(true) @map("include_in_export")
  createdAt           DateTime @default(now()) @map("created_at")

  guide Guide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@map("guide_steps")
}

model PublishLog {
  id          String   @id @default(uuid())
  guideId     String   @map("guide_id")
  platform    String
  externalId  String?  @map("external_id")
  externalUrl String?  @map("external_url")
  status      String   @default("pending")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("publish_logs")
}
