# Database
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Optional: set on every **new** workspace created at first auth sync (single-tenant / default org tag).
# Stored as lowercase slug on `workspaces.org_key` and copied to recordings & guides as `org_key`.
# Example: xertilox
# DEFAULT_WORKSPACE_ORG_KEY=

# Supabase (auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Public URL for email confirmation / password reset links. Required for local dev when using
# `next dev --hostname 0.0.0.0` (otherwise links point at http://0.0.0.0:3000 and the browser errors).
# NEXT_PUBLIC_APP_URL=http://localhost:3000
#
# Production: https://your-domain.com
#
# Supabase Dashboard → Authentication → URL Configuration:
# - Site URL: same as above (e.g. http://localhost:3000)
# - Redirect URLs: http://localhost:3000/auth/callback (and production callback URL)
# Enable MFA under Authentication → Multi-factor if you use TOTP in Settings.

# “Record from phone”: phones cannot open http://localhost — use your PC’s LAN IP or a tunnel URL:
# NEXT_PUBLIC_CAST_BASE_URL=http://192.168.1.10:3000
# Optional: comma-separated hosts allowed in QR API (staging / split DNS)
# CAST_QR_ALLOWED_HOSTS=preview.example.com:443

# Optional: WebRTC TURN for “Record from phone” when phone & PC are on strict NATs / different networks
# NEXT_PUBLIC_TURN_URL=turn:your.turn.host:3478
# NEXT_PUBLIC_TURN_USERNAME=
# NEXT_PUBLIC_TURN_CREDENTIAL=

# Weekly digest cron (required in production for /api/cron/weekly-digest)
# Generate: openssl rand -hex 32
CRON_SECRET=

# Optional: send digest emails via https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL="ShowcaseIt <onboarding@resend.dev>"

# Guide generation from recordings: max steps after extraction (default scales with marker count, clamped max 800)
# GUIDE_GENERATE_MAX_FRAMES=

# Marketing export (ffmpeg): `next dev` runs jobs in-process automatically. For production, run
# `npm run worker:marketing` from the repo root, or set MARKETING_RENDER_INLINE=1 on your Node server.
# MARKETING_RENDER_INLINE=0
# MARKETING_RENDER_USE_STUB=1
