# Database
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Supabase (auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# “Record from phone”: phones cannot open http://localhost — use your PC’s LAN IP or a tunnel URL:
# NEXT_PUBLIC_CAST_BASE_URL=http://192.168.1.10:3000
# Optional: comma-separated hosts allowed in QR API (staging / split DNS)
# CAST_QR_ALLOWED_HOSTS=preview.example.com:443

# Optional: WebRTC TURN for “Record from phone” when phone & PC are on strict NATs / different networks
# NEXT_PUBLIC_TURN_URL=turn:your.turn.host:3478
# NEXT_PUBLIC_TURN_USERNAME=
# NEXT_PUBLIC_TURN_CREDENTIAL=

# Weekly digest cron (required in production for /api/cron/weekly-digest)
# Generate: openssl rand -hex 32
CRON_SECRET=

# Optional: send digest emails via https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL="ShowcaseIt <onboarding@resend.dev>"

# Guide generation from recordings: max steps after extraction (default scales with marker count, clamped max 800)
# GUIDE_GENERATE_MAX_FRAMES=
