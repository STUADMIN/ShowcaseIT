{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && npm install --workspace=@showcaseit/web",
  "buildCommand": "NODE_OPTIONS=--max-old-space-size=8192 npm run build",
  "crons": [
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 1"
    }
  ]
}
