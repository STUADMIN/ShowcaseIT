# Copy to `.env.local` and fill keys from Supabase Dashboard → Project Settings → API
# Project: itvhynuikvpbzldexwvl → https://supabase.com/dashboard/project/itvhynuikvpbzldexwvl

# Optional: "true" = home/dashboard use a fake user without signing in (for UI-only tests).
# Leave unset for normal dev with real Supabase sign-in.
# NEXT_PUBLIC_DEV_AUTH_BYPASS=true

NEXT_PUBLIC_SUPABASE_URL=https://itvhynuikvpbzldexwvl.supabase.co
# Dashboard → Settings → API: publishable key (sb_publishable_…) or legacy anon JWT (eyJ…)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy alias (same value as above if both are set, publishable wins)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — never expose to the browser. Needed for `npm run seed:mock`.
SUPABASE_SERVICE_ROLE_KEY=
# Optional; admin client falls back to NEXT_PUBLIC_SUPABASE_URL if unset
# SUPABASE_URL=https://itvhynuikvpbzldexwvl.supabase.co

# ── Charity Commission Register API (server only) ───────────────────
# Required for Step 2 save + CC refetch (trustee snapshot, About your charity).
# Get a subscription key: https://api-portal.charitycommission.gov.uk/ (sign in → Products/APIs → subscribe)
# (Older hub: https://register-of-charities.charitycommission.gov.uk/developer)
CHARITY_COMMISSION_SUBSCRIPTION_KEY=
