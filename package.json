{
  "name": "showcaseit",
  "private": true,
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:direct": "npm run dev:direct -w @showcaseit/web",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@showcaseit/web",
    "dev:desktop": "turbo dev --filter=@showcaseit/desktop",
    "build:web": "turbo build --filter=@showcaseit/web",
    "build:desktop": "turbo build --filter=@showcaseit/desktop",
    "worker:marketing": "npm run worker:marketing -w @showcaseit/web",
    "docs:scan": "npm run docs:scan -w @showcaseit/web",
    "docs:generate": "npm run docs:generate -w @showcaseit/web",
    "guides:import": "npm run guides:import -w @showcaseit/web",
    "hr:generate": "npm run hr:generate -w @showcaseit/web"
  },
  "devDependencies": {
    "prisma": "^6.19.3",
    "turbo": "latest",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
