{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --workspace=@showcaseit/web",
  "buildCommand": "NODE_OPTIONS=--max-old-space-size=8192 npm run build -w @showcaseit/web",
  "outputDirectory": "apps/web/.next",
  "crons": [
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 1"
    }
  ]
}
